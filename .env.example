# Copy to .env and fill in real values. NEVER commit .env to git.
#
# ========================================
# MODE: Choose CLOUD or LOCAL
# ========================================
#
# LOCAL MODE (on-premise, data never leaves your machine):
#   MEDSCRIBE_LLM_BACKEND=ollama
#   MEDSCRIBE_STT_BACKEND=local
#   → No API keys needed. No internet needed (after model download).
#
# CLOUD MODE (faster setup, needs API key):
#   MEDSCRIBE_LLM_BACKEND=openai
#   MEDSCRIBE_STT_BACKEND=openai
#   → Requires OpenAI API key. Data sent to OpenAI servers.
#
# MIX MODE (local STT + cloud LLM, or vice versa):
#   MEDSCRIBE_LLM_BACKEND=openai
#   MEDSCRIBE_STT_BACKEND=local
#   → Audio stays local, only text goes to cloud for structuring.

# Core
MEDSCRIBE_ENVIRONMENT=dev
MEDSCRIBE_DEBUG=true

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MEDSCRIBE_SECRET_KEY=CHANGE-ME

# ---- LOCAL MODE (recommended for healthcare / privacy) ----
MEDSCRIBE_LLM_BACKEND=ollama
MEDSCRIBE_OLLAMA_BASE_URL=http://localhost:11434
MEDSCRIBE_OLLAMA_MODEL=llama3.1
MEDSCRIBE_STT_BACKEND=local
MEDSCRIBE_WHISPER_MODEL=base
MEDSCRIBE_WHISPER_DEVICE=cpu

# ---- CLOUD MODE (uncomment to use OpenAI) ----
# MEDSCRIBE_LLM_BACKEND=openai
# MEDSCRIBE_OPENAI_API_KEY=sk-...
# MEDSCRIBE_OPENAI_MODEL=gpt-4o
# MEDSCRIBE_STT_BACKEND=openai

# Database — for prod use PostgreSQL:
# MEDSCRIBE_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/medscribe
MEDSCRIBE_DATABASE_URL=sqlite+aiosqlite:///./medscribe.db

# Safety
MEDSCRIBE_REQUIRE_HUMAN_APPROVAL=true

# Webhooks (optional)
# MEDSCRIBE_WEBHOOK_URL=https://your-system.com/hooks/medscribe
# MEDSCRIBE_WEBHOOK_SECRET=your-webhook-secret
